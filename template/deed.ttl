        sh:property           [ rdfs:label   "Neighbourhood code"@en , "Buurtcode"@nl;
                                sh:datatype  xsd:string;
                                sh:maxCount  1;
                                sh:order     4.0;
                                sh:path      saa:historicalAddressNeighbourhoodCode
                              ];
        sh:property           [ rdfs:label   "Street name (1853-74)"@en , "Straatnaam (1853-74)"@nl;
                                sh:datatype  xsd:string;
